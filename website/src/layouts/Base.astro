---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="REALMVOID — Noir-Ermittlungen zwischen den Ebenen. Agnon City 2226 AD. Open Source Cyberpunk-Noir Franchise." />
  <meta name="theme-color" content="#0a0a0c" />

  <meta property="og:title" content="REALMVOID" />
  <meta property="og:description" content="Noir-Ermittlungen zwischen den Ebenen. Agnon City 2226 AD." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://realmvoid.com" />
  <meta property="og:image" content="https://realmvoid.com/assets/REALMVOID-LOGO.png" />

  <link rel="icon" type="image/png" href="/assets/REALMVOID-LOGO.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet" />

  <title>{title}</title>
</head>
<body>
  <div class="scanlines"></div>
  <div class="noise"></div>
  <slot />
</body>
</html>

<style is:global>
  *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }

  :root {
    --bg:       #0a0a0c;
    --surface:  #111114;
    --surface2: #1a1a1f;
    --border:   #2a2a30;
    --text:     #c8c8cc;
    --text-dim: #666670;
    --text-bright: #eeeef0;
    --accent:   #ff3b3b;
    --meat:     #a0c4a8;
    --net:      #4ecdc4;
    --aether:   #c4a0c4;
    --dead:     #555560;
    --font-mono: 'JetBrains Mono', monospace;
    --font-boot: 'Share Tech Mono', monospace;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 16px;
    line-height: 1.6;
    scroll-behavior: smooth;
    overflow-x: hidden;
  }

  body { position: relative; min-height: 100vh; }

  .scanlines {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 2px,
      rgba(0,0,0,0.08) 2px,
      rgba(0,0,0,0.08) 4px
    );
  }

  .noise {
    pointer-events: none;
    position: fixed;
    inset: 0;
    z-index: 9998;
    opacity: 0.03;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  ::selection {
    background: var(--accent);
    color: var(--bg);
  }

  a {
    color: var(--net);
    text-decoration: none;
    transition: color 0.2s;
  }
  a:hover { color: var(--text-bright); }
</style>
